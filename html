                ];
                allGovernorates.forEach(govName => {
                    globalBatch.set(doc(db, "governorates", govName), { totalPoints: 0 }, { merge: true });
                });

                // 2. جلب جميع المستخدمين لغرض تصفيرهم وتوزيع الجوائز
                const qAll = query(collection(db, "users"), where("points", ">", 0));
                const snapAll = await getDocs(qAll);
                
                let allSortedUsers = [];
                snapAll.docs.forEach(d => {
                    allSortedUsers.push({ id: d.id, ...d.data(), points: d.data().points || 0 });
                });
                allSortedUsers.sort((a, b) => b.points - a.points);
                
                const prizes = [10, 7, 5, 3, 2, 1, 1, 1, 1, 1];
                let batchesArray = [];
                let operationCount = allGovernorates.length; // حساب العمليات السابقة

                // 3. تصفير اللاعبين، إضافة الفلوس، وإنشاء الإشعارات
                allSortedUsers.forEach((uData, index) => {
                    let updates = { points: 0, previousPoints: uData.points || 0 };
                    let myRank = index + 1;
                    let isWinner = myRank <= 10 && (uData.points || 0) >= 150;

                    if (isWinner) {
                        let prize = prizes[index]; // الأموال ثابتة بدون مضاعفات للمميزين نهائياً
                        
                        updates.balance = (uData.balance || 0) + prize;
                        updates.lastWeeklyPrize = prize;
                        updates.lastWeeklyRank = myRank;
                        
                        // حفظ أفضل وأسوء مركز حققه اللاعب في حياته
                        if (!uData.bestRank || myRank < uData.bestRank) {
                            updates.bestRank = myRank; // كلما قل الرقم يعني المركز أفضل
                        }
                        if (!uData.worstRank || myRank > uData.worstRank) {
                            updates.worstRank = myRank;
                        }

                        // بناء الإشعار
                        let govRank = 0;
                        let govMsg = "\n\n🚩 لم تختر محافظة لتمثيلها.";
                        if (uData.governorate && govsList.length > 0) {
                            govRank = govsList.findIndex(g => g.id === uData.governorate) + 1;
                            if (govRank === 1 && winningGov) {
                                govMsg = `\n\n🚩 احتلت محافظتك (${uData.governorate}) المركز الأول وفزت بشعار البطل لمدة 7 أيام! 👑`;
