                            read: false, createdAt: serverTimestamp()
                        });
                        operationCount++;
                    }

                    globalBatch.update(doc(db, "users", uData.id), updates);
                    operationCount++;

                    if (operationCount >= 480) {
                        batchesArray.push(globalBatch.commit());
                        globalBatch = writeBatch(db);
                        operationCount = 0;
                    }
                });

                if (operationCount > 0) batchesArray.push(globalBatch.commit());
                await Promise.all(batchesArray);

