        async function getQuestions(sub, chapter, type) {
    if (!userData.grade) return [];
    
    let gradeCondition = userData.grade;
    
    // الشرط الصارم: المشترك فقط للسادس العلمي والأدبي حصراً
    if (sharedSubjects.includes(sub)) {
        if (userData.grade === '6sci' || userData.grade === '6lit') {
            gradeCondition = ['6sci', '6lit'];
        } else {
            gradeCondition = '3med'; 
        }
    }
    
    // --- التعديل الجذري (0 قراءات Firestore) ---
    // 1. التأكد من وجود الأسئلة في الرام، وإذا ماكو نجيبها من الذاكرة الداخلية
    if (!window.cachedQuestionsArray || window.cachedQuestionsArray.length === 0) {
        const localData = await localforage.getItem('all_questions_data');
        if (localData && localData.length > 0) {
            window.cachedQuestionsArray = localData;
        } else {
            showBeautifulAlert('warning', 'تحديث مطلوب', 'يجب الانتظار قليلاً أو إعادة تشغيل التطبيق لتحميل حزمة الأسئلة الأساسية.');
            return [];
        }
    }

    // 2. الفلترة المحلية (Local Filtering) سريعة كالبرق ومجانية 100%
    const list = window.cachedQuestionsArray.filter(q => {
        // فحص المرحلة
        const matchesGrade = Array.isArray(gradeCondition) ? gradeCondition.includes(q.grade) : (q.grade === gradeCondition);
        // فحص باقي الشروط
        const matchesSubject = q.subject === sub;
        const matchesChapter = q.chapter === chapter;
        const matchesType = q.type === type;
        
        return matchesGrade && matchesSubject && matchesChapter && matchesType;
    });

    return list;
}
        
