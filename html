    } catch (error) {
        console.error("Error starting revenge match:", error);
        showBeautifulAlert('error', 'خطأ', 'حدث خطأ في بدء مباراة الانتقام');
    }
};

async function promptForRevengeSubject(opponentName) {
    return new Promise((resolve) => {
        const modal = document.createElement('div');
        modal.className = 'modal-overlay';
        modal.style.display = 'flex';
        modal.style.zIndex = '99999';
        modal.innerHTML = `
            <div class="modal-content" style="max-width: 350px;">
                <div class="text-center mb-4">
                    <h3 class="font-bold text-lg text-indigo-700">اختيار المادة للانتقام</h3>
                    <p class="text-sm text-gray-600 mb-4">اختر المادة والفصل الذي تريد الانتقام في ${opponentName} به</p>
                </div>
                <label class="block text-xs font-bold text-gray-600 mb-1">المادة</label>
                <select id="revenge-subject-select" class="input-box mb-3">
                    <option value="">اختر المادة</option>
                </select>
                <label class="block text-xs font-bold text-gray-600 mb-1">الفصل</label>
                <select id="revenge-chapter-select" class="input-box mb-4">
                    <option value="">اختر المادة أولاً</option>
                </select>
                <div class="flex gap-3">
                    <button onclick="cancelRevengeSubject()" class="flex-1 bg-gray-100 text-gray-600 py-3 rounded-xl font-bold">إلغاء</button>
                    <button onclick="confirmRevengeSubject()" class="flex-1 bg-red-600 text-white py-3 rounded-xl font-bold hover:bg-red-700">بدء الانتقام 🔥</button>
                </div>
            </div>
        `;
        
        document.body.appendChild(modal);
        
        const subjectSelect = modal.querySelector('#revenge-subject-select');
        const chapterSelect = modal.querySelector('#revenge-chapter-select');
        
        if (userData.grade && subjects[userData.grade]) {
            subjects[userData.grade].forEach(sub => {
                subjectSelect.innerHTML += `<option value="${sub}">${sub}</option>`;
            });
        }
        
        // عند تغيير المادة نقوم بجلب الفصول الخاصة بها
        subjectSelect.onchange = function() {
            chapterSelect.innerHTML = '<option value="">اختر الفصل</option>';
            if (chaptersData[userData.grade] && chaptersData[userData.grade][this.value]) {
                chaptersData[userData.grade][this.value].forEach(ch => {
                    chapterSelect.innerHTML += `<option value="${ch}">${ch}</option>`;
                });
            }
        };
        
        window.cancelRevengeSubject = function() {
            document.body.removeChild(modal);
            resolve(null);
        };
        
        window.confirmRevengeSubject = function() {
            const selectedSubject = subjectSelect.value;
            const selectedChapter = chapterSelect.value;
            if (!selectedSubject || !selectedChapter) {
                showBeautifulAlert('warning', 'تنبيه', 'يرجى اختيار المادة والفصل');
                return;
            }
            document.body.removeChild(modal);
            resolve({ subject: selectedSubject, chapter: selectedChapter });
        };
    });
}

