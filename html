            }
            
            document.getElementById('game-overlay').appendChild(display);
            currentEmojiDisplay = display;
            
            // إخفاء الغيمة بعد 2.5 ثانية (وقت كافي وجميل)
            setTimeout(() => {
                if (display.parentNode) {
                    display.style.animation = 'none'; // نوقف الطوفان
                    display.style.opacity = '0';
                    display.style.transform = 'translateY(10px) scale(0.8)';
                    display.style.transition = 'all 0.3s ease-in';
                    setTimeout(() => {
                        if(display.parentNode) display.remove();
                        currentEmojiDisplay = null;
