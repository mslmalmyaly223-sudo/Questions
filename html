    const chapter = document.getElementById('bulk-ai-chapter').value;
    
    if (!fileInput.files[0] || !grade || !subject || !chapter) {
        showBeautifulAlert('warning', 'نقص معلومات', 'يرجى رفع الملف واختيار الصف والمادة والفصل/الموضوع بدقة');
        return;
    }

    const btn = document.getElementById('bulk-add-queue-btn');
    const readProgress = document.getElementById('ai-read-progress');
    const readBar = document.getElementById('ai-read-bar');
    
    btn.disabled = true;
    btn.classList.add('opacity-50');
    readProgress.classList.remove('hidden');

    try {
        const pdfjs = window.pdfjsLib || window['pdfjs-dist/build/pdf'];
        pdfjs.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.worker.min.js';
        
        const file = fileInput.files[0];
        const arrayBuffer = await file.arrayBuffer();
        const pdf = await pdfjs.getDocument({data: arrayBuffer}).promise;
        
        let fullText = '';
        for (let i = 1; i <= pdf.numPages; i++) {
            const page = await pdf.getPage(i);
            const content = await page.getTextContent();
            fullText += content.items.map(s => s.str).join(' ') + '\n';
            readBar.style.width = Math.round((i / pdf.numPages) * 100) + '%';
        }

        const queue = getAIQueue();
        
        if (fullText.trim().length > 0) {
            queue.push({
                id: Date.now().toString(),
                grade: grade,
                subject: subject,
                chapter: chapter,
                type: 'mixed', // تم التعديل لتشمل النوعين
                fullText: fullText, 
                totalChunks: 1, 
                processedChunks: 0,
                status: 'waiting', 
                questions: [],
                createdAt: Date.now()
            });
            showBeautifulAlert('success', 'تم الإضافة', `تمت إضافة الملف! سيتم استخراج (الاختيارات والصح والخطأ) معاً بضربة واحدة 🚀.`);
        }

        saveAIQueue(queue);
        
        fileInput.value = '';
        readProgress.classList.add('hidden');
        readBar.style.width = '0%';
        btn.disabled = false;
        btn.classList.remove('opacity-50');

        startAIQueueProcessor();

    } catch (error) {
        console.error("PDF Read Error:", error);
        showBeautifulAlert('error', 'خطأ في الملف', 'حدث خطأ أثناء قراءة ملف الـ PDF');
        readProgress.classList.add('hidden');
        btn.disabled = false;
        btn.classList.remove('opacity-50');
    }
};

