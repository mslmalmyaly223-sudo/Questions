        window.acceptAllPendingQuestions = async function() {
            if(!confirm("هل أنت متأكد من قبول جميع الطلبات والاقتراحات المعلقة؟")) return;
            try {
                const q = query(collection(db, "pending_questions"), where("status", "==", "pending"));
                const snap = await getDocs(q);
                
                if(snap.empty) {
                    showBeautifulAlert('info', 'لا يوجد', 'لا توجد طلبات معلقة للموافقة عليها.');
