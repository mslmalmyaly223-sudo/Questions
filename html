            try {
                const q = query(collection(db, "users"), where("isPremium", "==", true));
                const snap = await getDocs(q);
                
                let html = '';
                const now = new Date();
                let activePremiumCount = 0;
                
                snap.docs.forEach(userDoc => {
                    const u = userDoc.data();
                    let remainingDays = "منتهي";
                    let isValid = false;

                    // التحقق الدقيق من تاريخ الانتهاء
                    if (u.premiumExpiry) {
                        const expiry = u.premiumExpiry.toDate();
                        const diff = expiry - now;
                        if(diff > 0) {
                            isValid = true;
                            remainingDays = Math.ceil(diff / (1000 * 60 * 60 * 24)) + " يوم";
                        }
                    }

                    // إذا كان الوقت قد انتهى، نقوم بإلغاء اشتراكه فوراً في قاعدة البيانات ولا نعرضه
                    if (!isValid) {
                        deactivatePremiumFeatures(userDoc.id); 
                        return; // لا تعرضه في القائمة
                    }
                    
                    activePremiumCount++;
                    html += `
                        <div class="bg-white rounded-xl p-4 border border-yellow-100 shadow-sm">
