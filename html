async function findRandomOpponent(sub, chapter) {
    console.log("البحث عن منافس عشوائي للمادة والفصل:", sub, chapter);
    try {
        // ✅ اقتصادي: يجلب 25 مستخدم فقط 
        const q = query(collection(db, "users"), where("grade", "==", userData.grade), limit(25));
        const snap = await getDocs(q);
                
                if (snap.empty) {
                    showBeautifulAlert('warning', 'تنبيه', 'لا يوجد منافسين متاحين حالياً');
                    cancelSearch();
                    return;
                }
                
                let eligibleUsers = [];
                let usersWithRealPhotos = [];
                
                snap.forEach(doc => {
                    const user = doc.data();
                    if (user.uid && user.uid !== currentUser.uid) {
                        const userDataObj = { id: doc.id, ...user };
                        eligibleUsers.push(userDataObj);
                        
                        // عزل المستخدمين اللي حاطين صور حقيقية لحساباتهم
                        if (user.photo && !user.photo.includes("ui-avatars.com")) {
                            usersWithRealPhotos.push(userDataObj);
                        }
                    }
                });
                
                if (eligibleUsers.length === 0) {
                    showBeautifulAlert('warning', 'تنبيه', 'لا يوجد منافسين متاحين حالياً');
                    cancelSearch();
                    return;
                }
                
                // الخوارزمية الذكية: نعتمد على أصحاب الصور الحقيقية كأولوية، وإذا ماكو نعتمد على الكل
                // الخوارزمية الصارمة: يجب أن يكون الخصم لديه صورة حقيقية فقط
        let poolToUse = usersWithRealPhotos;

        if (poolToUse.length === 0) {
            showBeautifulAlert('warning', 'عذراً', 'لا يوجد منافسين متاحين يمتلكون صورة شخصية حالياً، حاول لاحقاً.');
            cancelSearch();
            return;
        }

                // ترتيب القائمة حسب "آخر ظهور" (من الأحدث للأقدم)
                poolToUse.sort((a, b) => {
                    const dateA = a.lastLogin ? new Date(a.lastLogin).getTime() : 0;
                    const dateB = b.lastLogin ? new Date(b.lastLogin).getTime() : 0;
                    return dateB - dateA;
                });

                // جلب قائمة الخصوم اللي لعبت وياهم مؤخراً من ذاكرة هاتفك (حتى ما يتكررون)
                let recentOpponents = JSON.parse(localStorage.getItem('recent_opponents_cycle') || '[]');

                let chosenOpponent;
                
                // البحث عن أول شخص بالترتيب (أحدث ظهور) ما لعبت وياه بهاي الدورة
                let availableOpponents = poolToUse.filter(op => !recentOpponents.includes(op.id));

// إذا لعبت وي الكل، أو الدورة وصلت 25 شخص.. نصفر السجل ونستعمل كل القائمة من جديد
if (availableOpponents.length === 0 || recentOpponents.length >= 25) {
    recentOpponents = [];
    availableOpponents = poolToUse;
}

// التعديل الأهم: اختيار شخص (عشوائي) من القائمة مو أول واحد دائماً
const randomIndex = Math.floor(Math.random() * availableOpponents.length);
chosenOpponent = availableOpponents[randomIndex];

// حفظ الخصم الحالي بالقائمة حتى ما يطلعلك بالمباراة الجاية مباشرة
recentOpponents.push(chosenOpponent.id);
localStorage.setItem('recent_opponents_cycle', JSON.stringify(recentOpponents));
                
                await showVSAnimationWithButtons(
                    { uid: currentUser.uid, name: userData.name, photo: userData.photo, grade: userData.grade },
                    { uid: chosenOpponent.id, name: chosenOpponent.name, photo: chosenOpponent.photo, grade: chosenOpponent.grade },
                    chapter // تمرير الفصل
                );
                
            } catch (error) {
                console.error("Error finding opponent:", error);
                showBeautifulAlert('error', 'خطأ', 'حدث خطأ في البحث عن منافس');
                cancelSearch();
            }
        }

