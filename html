        if (isPremiumValid(u) && u.selectedBgTheme && u.selectedBgTheme !== 'bg-rank-default') {
            if (headerBg) headerBg.className = `w-full h-28 relative rounded-b-[2.5rem] shadow-md z-10 transition-all duration-500 bg-transparent`;
            if (fullBg) {
                fullBg.className = `absolute inset-0 z-0 transition-all duration-500 ${u.selectedBgTheme}`;
                fullBg.style.opacity = '0.95';
            }

            const bgEmojiMap = {
                'bg-love': '❤️', 'bg-medical': '✚', 'bg-law': '⚖️', 'bg-edu': '🎓',
                'bg-eng': '⚙️', 'bg-smart': '💡', 'bg-space': '🌑', 'bg-galaxy': '🌌',
                'bg-fire': '🔥', 'bg-ocean': '🌊', 'bg-forest': '🍃', 'bg-hacker': '💻',
                'bg-royal': '👑', 'bg-neon': '✨', 'bg-cyberpunk': '👾', 'bg-crystal': '💎'
            };

            const selectedEmoji = bgEmojiMap[u.selectedBgTheme] || '🌟';
            const oldContainer = document.querySelector('#screen-public-profile .floating-emojis-container');
            if (oldContainer) oldContainer.remove();

            const container = document.createElement('div');
            container.className = 'floating-emojis-container';
            container.style.cssText = `position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; pointer-events: none; overflow: hidden;`;

            const positions = [
                { top: '8%', left: '15%' }, { top: '12%', left: '75%' },
                { top: '40%', left: '3%' }, { top: '45%', left: '50%' },
                { top: '38%', left: '90%' }, { top: '78%', left: '15%' }, { top: '82%', left: '75%' }
            ];

            for (let i = 0; i < 7; i++) {
                const emoji = document.createElement('div');
                emoji.innerText = selectedEmoji;
                emoji.style.cssText = `position: absolute; font-size: 38px; top: ${positions[i].top}; left: ${positions[i].left}; opacity: 0.55; filter: drop-shadow(0 0 3px rgba(255,255,255,0.3)); pointer-events: none; animation: floatHorizontal${i} ${12 + (i * 1.5)}s linear infinite; z-index: 1;`;

                const styleId = `dynamic-emoji-style-${i}`;
                if (!document.querySelector(`#${styleId}`)) {
                    const style = document.createElement('style');
                    style.id = styleId;
                    style.textContent = `@keyframes floatHorizontal${i} { 0% { transform: translateX(0%); opacity: 0.55; } 50% { opacity: 0.85; } 100% { transform: translateX(-150%); opacity: 0.55; } }`;
                    document.head.appendChild(style);
