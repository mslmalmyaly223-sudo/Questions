function getStudentSmartEmoji(studentAnsweredCorrectly, userWasCorrect) {
    // حالة 1: الطالب جاوب صح، وأنت أخطأت (انفجار شماتة وضحك هستيري)
    if (studentAnsweredCorrectly && !userWasCorrect) {
        return Math.random() > 0.3 ? '😂' : '🥲'; // نسبة ضحك عالية جداً
    }
    // حالة 2: الطالب أخطأ، وأنت صح (حقد وغضب شديد)
    if (!studentAnsweredCorrectly && userWasCorrect) {
        return '😡'; // غضب فوري
    }
    // حالة 3: كلاكما صح (نظرة احتقار واستفزاز)
    if (studentAnsweredCorrectly && userWasCorrect) {
        return '😒'; 
    }
    // حالة 4: كلاكما خطأ (انهيار)
    if (!studentAnsweredCorrectly && !userWasCorrect) {
        return Math.random() > 0.5 ? '😭' : '😔'; 
    }
    return '😂';
}


        async function submitGameAnswer(ansObj, q, matchData) {
    if(hasAnsweredCurrentQ || isExitingGame) return;
    hasAnsweredCurrentQ = true;
    userAnsweredCorrectly = ansObj && ansObj.isCorrect;
    
    // تعطيل التفاعلات بعد الإجابة
    emojiUsedInCurrentQuestion = true;
    disableEmojiButtons();
    
    const answerButtons = document.querySelectorAll('#answers-container button');
    answerButtons.forEach(btn => {
        btn.classList.remove('answer-correct', 'answer-wrong', 'answer-neutral');
        if (btn.dataset.value.toString() === currentQuestionCorrectAnswer.toString()) btn.classList.add('answer-correct');
        else if (ansObj && btn.dataset.value.toString() === (ansObj.value?.toString())) btn.classList.add('answer-wrong');
        else btn.classList.add('answer-neutral');
    });
    
    // --- الإضافة: تشغيل صوت الصح والخطأ ---
    if(userAnsweredCorrectly) {
        playSound('correct');
    } else {
        playSound('wrong');
    }

    document.getElementById('answers-container').classList.add('pointer-events-none');

    document.getElementById('waiting-msg').classList.add('hidden'); 
    if(ansObj && ansObj.isCorrect) {
        localMatchData.player1.score += 1;
        document.getElementById('game-my-score').innerText = localMatchData.player1.score;
    }
    
    if (userAnsweredCorrectly) {
        localMatchData.player1.currentStreak = (localMatchData.player1.currentStreak || 0) + 1;
        if (localMatchData.player1.currentStreak > (localMatchData.player1.maxStreak || 0)) {
            localMatchData.player1.maxStreak = localMatchData.player1.currentStreak;
        }
    } else {
        localMatchData.player1.currentStreak = 0; // تصفير السلسلة عند الخطأ
    }
    
    if (currentGameMode === 'ai') {
        triggerAIResponse();
    } else {
        triggerStudentAIResponse();
    }
}

        

function triggerStudentAIResponse() {
    document.getElementById('waiting-msg').classList.remove('hidden');
    if (document.getElementById('ai-thinking-msg')) {
        document.getElementById('ai-thinking-msg').classList.add('hidden');
    }
    
    // السرعة: يجيب خلال أول 3 ثواني (من 1000 ملي ثانية إلى 3000)
    let delay = Math.random() * 2000 + 1000;
    // نسبة الطالب العشوائي 80% بناءً على طلبك
    let accuracy = 0.80;
    
    if (Math.random() < 0.3) {
        document.getElementById('weak-signal').classList.remove('hidden');
        setTimeout(() => {
            document.getElementById('weak-signal').classList.add('hidden');
        }, 2000);
    }
    
    aiTimeoutId = setTimeout(() => {
        const isCorrect = Math.random() < accuracy;
        
        // الطالب العشوائي يتفاعل مع كل سؤال (100%) وبقمة الخبث
        const studentEmoji = getStudentSmartEmoji(isCorrect, userAnsweredCorrectly);
        showEmoji(studentEmoji, 'ai');
        
        if(isCorrect) {
            localMatchData.player2.score += 1;
            document.getElementById('game-op-score').innerText = localMatchData.player2.score;
        }
        
        handleAINextTurn();
    }, delay);
}

