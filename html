window.showAchievementsList = function() {
    if (!userData || !userData.grade) {
        showBeautifulAlert('warning', 'تنبيه', 'يجب تحديد المرحلة الدراسية أولاً من التحديات');
        return;
    }
    
    const container = document.getElementById('achievements-details-container');
    container.innerHTML = '';
    
    const userGrade = userData.grade;
    const completed = userData.completedChapters || [];
    const gradeSubjects = subjects[userGrade] || [];
    
    if (gradeSubjects.length === 0) {
        container.innerHTML = '<p class="text-center text-gray-500 mt-10 font-bold">لا توجد مواد متاحة لمرحلتك.</p>';
        document.getElementById('achievements-list-modal').classList.remove('hidden');
        return;
    }

    let html = '';
    
    gradeSubjects.forEach(sub => {
        const subjectChapters = chaptersData[userGrade][sub] || [];
        const totalSubChapters = subjectChapters.length;
        
        // جلب الفصول المنجزة لهذه المادة حصراً
        const completedInSub = subjectChapters.filter(chap => completed.includes(`${sub}_${chap}`));
        const completedCount = completedInSub.length;
        
        html += `
            <div class="bg-gray-50 rounded-xl border border-gray-200 overflow-hidden mb-3 shadow-sm">
                <div class="p-4 bg-white flex justify-between items-center cursor-pointer hover:bg-indigo-50 transition-colors" onclick="this.nextElementSibling.classList.toggle('hidden')">
                    <span class="font-black text-gray-800">${sub}</span>
                    <div class="flex items-center gap-3">
                        <span class="text-xs font-black ${completedCount === totalSubChapters ? 'text-white bg-green-500' : 'text-indigo-700 bg-indigo-100'} px-2.5 py-1 rounded-lg">
                            ${completedCount} / ${totalSubChapters}
                        </span>
                        <i class="fas fa-chevron-down text-gray-400 text-xs"></i>
                    </div>
                </div>
                <div class="hidden p-3 border-t border-gray-100 bg-gray-50 space-y-2">
        `;
        
        if (totalSubChapters === 0) {
            html += `<p class="text-xs text-gray-400 text-center font-bold">لا توجد فصول لهذه المادة</p>`;
        } else {
            subjectChapters.forEach(chap => {
                const isDone = completedInSub.includes(chap);
                html += `
                    <div class="flex justify-between items-center p-2.5 rounded-lg transition-all ${isDone ? 'bg-green-100 border border-green-300' : 'bg-white border border-gray-200'}">
                        <span class="text-xs font-bold ${isDone ? 'text-green-800' : 'text-gray-600'}">${chap}</span>
                        ${isDone ? '<i class="fas fa-check-circle text-green-600 text-lg"></i>' : '<i class="far fa-circle text-gray-300 text-lg"></i>'}
                    </div>
                `;
            });
        }
        
        html += `
                </div>
            </div>
        `;
    });
    
    container.innerHTML = html;
    document.getElementById('achievements-list-modal').classList.remove('hidden');
};

window.createQuestionsBundle = async function() {
    if (!confirm("هل أنت متأكد من رغبتك في تحديث حزمة الأسئلة ورفعها للطلاب؟\n(هذه العملية قد تستغرق بعض الوقت حسب عدد الأسئلة)")) return;

    const btn = document.getElementById('btn-create-bundle');
    const progText = document.getElementById('bundle-progress-text');
    btn.disabled = true;
    btn.classList.add('opacity-50');
    progText.classList.remove('hidden');

    try {
        progText.innerText = "جاري جلب جميع الأسئلة من قاعدة البيانات... (1/3)";
        // نجيب كل الأسئلة
        const qSnap = await getDocs(collection(db, "questions"));
        let allQuestions = [];
        
        qSnap.forEach(doc => {
            const data = doc.data();
            allQuestions.push({
                id: doc.id,
                question: data.question,
                answers: data.answers || [],
                correct: data.correct,
                type: data.type,
                grade: data.grade,
                subject: data.subject,
                chapter: data.chapter || ''
            });
        });

        progText.innerText = "جاري تكوين الملف وضغطه... (2/3)";
        // تحويل المصفوفة إلى ملف نصي (JSON Blob)
        const jsonString = JSON.stringify(allQuestions);
        const blob = new Blob([jsonString], { type: "application/json" });

        progText.innerText = "جاري الرفع إلى Storage التخزين... (3/3)";
        // رفع الملف للستورج
        const storageRef = ref(storage, 'system_files/questions_bundle.json');
        const snapshot = await uploadBytes(storageRef, blob);
        const downloadURL = await getDownloadURL(snapshot.ref);

        // حفظ الرابط وتاريخ التحديث بالاعدادات حتى يعرف الطالب اكو تحديث
        await setDoc(doc(db, "system_settings", "packet_info"), {
            bundleUrl: downloadURL,
            updatedAt: Date.now(),
            totalQuestions: allQuestions.length
        });

        showBeautifulAlert('success', 'عملية ناجحة', `تم تحديث الحزمة بنجاح! متوفر الآن ${allQuestions.length} سؤال للطلاب.`);
        
    } catch (error) {
        console.error("Bundle Error:", error);
        showBeautifulAlert('error', 'خطأ', 'حدث خطأ أثناء تكوين الحزمة: ' + error.message);
    } finally {
        btn.disabled = false;
        btn.classList.remove('opacity-50');
        progText.classList.add('hidden');
    }
};

window.deleteAITask = function(taskId) {
    if(!confirm("هل أنت متأكد من حذف هذا الملف من الطابور؟")) return;
    
    const queue = getAIQueue();
    const taskToDelete = queue.find(t => t.id === taskId);
    
    // فلترة الطابور لحذف الملف المختار
    const newQueue = queue.filter(t => t.id !== taskId);
    saveAIQueue(newQueue);
    
    // إذا كان الملف المحذوف هو اللي ديستخرج حالياً، لازم نكسر المعالجة ونشغل الملف البعده
    if (taskToDelete && taskToDelete.status === 'processing') {
        isQueueProcessing = false; // نوقف اللوب الحالي
        setTimeout(() => {
            if (newQueue.length > 0) {
                startAIQueueProcessor(); // نشغل الملف اللي بعده بالطابور
            }
        }, 1500);
    }
    
    showBeautifulAlert('success', 'تم الحذف', 'تم حذف الملف المعلك بنجاح.');
};

