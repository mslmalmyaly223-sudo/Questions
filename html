        async function endGame(d) {
    clearInterval(gameTimer);
    localStorage.removeItem('active_match_session');
    clearTimeout(aiTimeoutId);

    if (isExitingGame) return;

    let myScore = localMatchData.player1.score;
    let opScore = localMatchData.player2.score;
    let opName = localMatchData.player2.name;
    let opId = localMatchData.player2.uid;

    let pointsGained = 0;
    let pointsLost = 0;
    let msg = "";
    let icon = "";

    if (currentGameMode === 'achievement_test') {
        if (myScore >= 15) {
            msg = "بطل! أكملت الإنجاز";
            icon = "🌟";
            playSound('win');
            pointsGained = 20;
            pointsLost = 0;

            const key = `${localMatchData.subject}_${localMatchData.chapter}`;
            if (!userData.completedChapters) userData.completedChapters = [];
            userData.completedChapters.push(key);
            updateDoc(doc(db, "users", currentUser.uid), { completedChapters: userData.completedChapters });
            setTimeout(() => initAchievementSystem(), 1000);
        } else {
            msg = "كاذب! لم تكمل دراستك";
            icon = "❌";
            playSound('lose');
            pointsGained = 0;
            pointsLost = 10;
        }
    } else {
        if (myScore > opScore) {
            msg = "فوز ساحق!";
            icon = "🏆";
            playSound('win');
            pointsGained = myScore * 2;
            if (isPremiumValid(userData)) pointsGained *= 2;
        } else if (myScore < opScore) {
            msg = "حظ أوفر!";
            icon = "😢";
            playSound('lose');
            pointsLost = opScore;
        } else {
            msg = myScore > 0 ? "تعادل إيجابي!" : "تعادل سلبي!";
            icon = myScore > 0 ? "🤝" : "😐";
            playSound('draw');
            pointsGained = myScore > 0 ? myScore : 1;
        }
    }

    document.getElementById('game-overlay').classList.add('hidden');
    document.getElementById('withdraw-game-btn').classList.add('hidden');
    document.getElementById('emoji-container').classList.add('hidden');

    const resultScreen = document.getElementById('result-screen');
    document.getElementById('result-icon-container').innerText = icon;
    document.getElementById('result-title').innerText = msg;
    document.getElementById('final-my-score').innerText = myScore;
    document.getElementById('final-op-score').innerText = opScore;
    document.getElementById('final-op-name').innerText = opName;

    const pointsGainedText = document.getElementById('result-points-gained-text');
    if (pointsGained > 0 && (!window.isCurrentMatchFriendly || currentGameMode === 'achievement_test')) {
        pointsGainedText.innerText = `+${pointsGained}`;
        pointsGainedText.style.background = "linear-gradient(135deg, #fef3c7 0%, #fbbf24 100%)";
        pointsGainedText.style.color = "#92400e";
    } else if (pointsLost > 0 && !window.isCurrentMatchFriendly) {
        pointsGainedText.innerText = `-${pointsLost}`;
        pointsGainedText.style.background = "linear-gradient(135deg, #fee2e2 0%, #fecaca 100%)";
        pointsGainedText.style.color = "#991b1b";
    } else {
        pointsGainedText.innerText = "+0";
        pointsGainedText.style.background = "#f1f5f9";
        pointsGainedText.style.color = "#374151";
    }

    resultScreen.classList.remove('hidden');

    (async () => {
        try {
            let myChange = 0;

            if (currentGameMode === 'student') {
                let matchTypeTxt = window.isCurrentMatchFriendly ? "في مباراة ودية" : "في تحدي حقيقي";

                if (!window.isCurrentMatchFriendly) {
                    if (myScore > opScore) {
                        updateDoc(doc(db, "users", opId), { points: increment(-pointsGained) });
                    } else if (myScore < opScore) {
                        let opAdd = opScore * 2;
                        getDoc(doc(db, "users", opId)).then(opSnap => {
                            if (opSnap.exists()) {
                                let opData = opSnap.data();
                                if (opData.isPremium && opData.premiumExpiry?.toDate() > new Date()) opAdd *= 2;
                                updateDoc(doc(db, "users", opId), { points: increment(opAdd) });
                            }
                        });
                    }
                }

                if (myScore > opScore) {
                    addDoc(collection(db, "notifications"), {
                        userId: opId, type: 'revenge',
                        message: `🔥 إهانة كروية! ${matchTypeTxt} المنافس "${userData.name}" سحقك بنتيجة ${myScore}-${opScore} وخسرت نقاط. ثأر لكرامتك! ⚔️`,
                        opponentId: currentUser.uid, opponentName: userData.name, matchResult: `${opScore}-${myScore}`,
                        read: false, createdAt: serverTimestamp()
                    });
                } else if (myScore < opScore) {
                    addDoc(collection(db, "notifications"), {
                        userId: currentUser.uid, type: 'revenge',
                        message: `🔥 خسرت أمام "${opName}" بنتيجة ${opScore}-${myScore} ${matchTypeTxt}. هل ستنتقم؟ ⚔️`,
                        opponentId: opId, opponentName: opName, matchResult: `${myScore}-${opScore}`,
                        read: false, createdAt: serverTimestamp()
                    });

                    addDoc(collection(db, "notifications"), {
                        userId: opId, type: 'reward',
                        message: `🎉 مبروك! لقد فزت على "${userData.name}" بنتيجة ${opScore}-${myScore} ${matchTypeTxt} (أثناء غيابك) وتمت إضافة النقاط لرصيدك.`,
                        read: false, createdAt: serverTimestamp()
                    });
                }
            }

            if (!window.isCurrentMatchFriendly || currentGameMode === 'achievement_test') {
                myChange = pointsGained > 0 ? pointsGained : -pointsLost;

                let dbUpdates = {};
                if (myChange !== 0) dbUpdates.points = increment(myChange);

                if (myScore > opScore) {
                    userData.winStreak = (userData.winStreak || 0) + 1;
                    dbUpdates.winStreak = userData.winStreak;
                    if (userData.winStreak > (userData.bestWinStreak || 0)) {
                        userData.bestWinStreak = userData.winStreak;
                        dbUpdates.bestWinStreak = userData.winStreak;
                    }
                } else if (myScore < opScore) {
                    userData.winStreak = 0;
                    dbUpdates.winStreak = 0;
                }

                const matchMaxStreak = localMatchData.player1.maxStreak || 0;
                if (matchMaxStreak > (userData.bestCorrectStreak || 0)) {
                    userData.bestCorrectStreak = matchMaxStreak;
                    dbUpdates.bestCorrectStreak = matchMaxStreak;
                }

                if (userData.worstMatchScore === undefined || myScore < userData.worstMatchScore) {
                    userData.worstMatchScore = myScore;
                    dbUpdates.worstMatchScore = myScore;
                }

                await updateDoc(doc(db, "users", currentUser.uid), dbUpdates);
                userData.points += myChange;
                setupHeaderUI();

                if (pointsGained > 0 && userData.governorate) {
                    try {
                        updateDoc(doc(db, "governorates", userData.governorate), { totalPoints: increment(pointsGained) });
                    } catch (e) {}
                }
            }

            window.isCurrentMatchFriendly = false;
            checkNotifications();
        } catch (e) { console.error("Background DB Error:", e); }
    })();
}

        window.startRevengeMatch = async function(opponentId, opponentName) {
    try {
        const opponentDoc = await getDoc(doc(db, "users", opponentId));
        if (!opponentDoc.exists()) {
            showBeautifulAlert('error', 'خطأ', 'المنافس غير موجود');
            return;
        }
        
        const opponentData = opponentDoc.data();
        const selectedInfo = await promptForRevengeSubject(opponentName);
        if (!selectedInfo || !selectedInfo.subject || !selectedInfo.chapter) {
            showBeautifulAlert('warning', 'تنبيه', 'يرجى اختيار المادة والفصل بشكل صحيح للانتقام');
            return;
        }
        
        // إنشاء معرف مباراة فريد وموحد يجمع الطرفين للربط بينهما
        const matchRoomId = `revenge_${auth.currentUser.uid}_${opponentId}`;
        
        // رفع بيانات المباراة للفايربيس لضمان دخول الطرف الآخر واستماعه للمباراة فوراً
        await setDoc(doc(db, "active_matches", matchRoomId), {
            challengerId: auth.currentUser.uid,
            opponentId: opponentId,
            subject: selectedInfo.subject,
            chapter: selectedInfo.chapter,
            status: "waiting_opponent",
            mode: "revenge",
            createdAt: serverTimestamp()
        });

        selectedOpponent = {
            id: opponentId,
            name: opponentName,
            photo: opponentData.photo,
            grade: opponentData.grade,
            matchRoomId: matchRoomId // تمرير المعرف لـ startStudentMatch لربط الـ Sync
        };
        
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        document.getElementById('tab-challenges').classList.add('active');
        
        const subjectSelectElement = document.getElementById('challenge-subject');
        const chapterSelectElement = document.getElementById('challenge-chapter');
        if (subjectSelectElement) subjectSelectElement.value = selectedInfo.subject;
        if (chapterSelectElement) {
            chapterSelectElement.innerHTML = `<option value="${selectedInfo.chapter}">${selectedInfo.chapter}</option>`;
            chapterSelectElement.value = selectedInfo.chapter;
        }
        
        selectedQType = 'mcq';
        document.getElementById('btn-mcq').className = `py-3 rounded-xl border-2 font-bold transition flex-1 border-indigo-600 bg-indigo-50 text-indigo-600`;
        document.getElementById('btn-tf').className = `py-3 rounded-xl border-2 font-bold transition flex-1 border-indigo-100 text-gray-500`;
        
        setTimeout(() => {
            // تشغيل المباراة مع تمرير المعرف الموحد لضمان جودة الاتصال لجميع الأنواع
            startStudentMatch(selectedInfo.subject, selectedInfo.chapter, selectedOpponent);
