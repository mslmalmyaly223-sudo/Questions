            function updateTimer() {
                const now = getIraqDate();
                let nextFriday = new Date(now);
                let daysUntilFriday = (5 - now.getDay() + 7) % 7;

                // إذا كنا في يوم الجمعة ولكن بعد منتصف الليل، استهدف الجمعة القادمة
                if (daysUntilFriday === 0 && (now.getHours() > 0 || now.getMinutes() > 0 || now.getSeconds() > 0)) {
                    daysUntilFriday = 7;
                }

                nextFriday.setDate(now.getDate() + daysUntilFriday);
                nextFriday.setHours(0, 0, 0, 0);

                const diff = nextFriday - now;

                if (diff <= 1000 && diff > -59000) { // دقيقة واحدة لتأكيد التصفير
                    timerEl.innerText = "00:00:00:00";
                    checkAutoDistribute();
                } else {
                    const d = Math.floor(diff / (1000 * 60 * 60 * 24));
                    const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                    const s = Math.floor((diff % (1000 * 60)) / 1000);
                    timerEl.innerText = `${d}:${h<10?'0'+h:h}:${m<10?'0'+m:m}:${s<10?'0'+s:s}`;
                }
            }
            
            checkAutoDistribute();
            updateTimer();
            countdownInterval = setInterval(updateTimer, 1000);
        }

