window.startAIQueueProcessor = function() {
    if (isQueueProcessing) return;

    const queue = getAIQueue();
    let needsSave = false;
    
    // تحويل المهام اللي كانت قيد المعالجة (لو طفيت التطبيق بالغلط) إلى انتظار حتى ترجع تشتغل
    queue.forEach(t => {
        if (t.status === 'processing') {
            t.status = 'waiting'; 
            needsSave = true;
        }
    });
    if (needsSave) saveAIQueue(queue);

    isQueueProcessing = true;
    
    // إرسال أمر للأندرويد حتى يخلي التطبيق شغال بالخلفية
    if(typeof window.SketchwareJS !== 'undefined' && window.SketchwareJS.startBackgroundService) {
        window.SketchwareJS.startBackgroundService();
    }
    
    // استدعاء الدالة لمرة واحدة، وهي راح تتكفل بالباقي وتسوي دوران ذكي
    processNextInQueue(); 
};

async function processNextInQueue() {
    const cooldownUntil = localStorage.getItem('admin_ai_cooldown');
    const cooldownBanner = document.getElementById('ai-cooldown-banner');
    const timerText = document.getElementById('ai-cooldown-timer');

    if (cooldownUntil && Date.now() < parseInt(cooldownUntil)) {
        if (cooldownBanner) {
            cooldownBanner.classList.remove('hidden');
            const diffMs = parseInt(cooldownUntil) - Date.now();
            const minutes = Math.floor(diffMs / 60000);
            const seconds = Math.floor((diffMs % 60000) / 1000);
            if (timerText) timerText.innerText = `${minutes}:${seconds < 10 ? '0'+seconds : seconds}`;
        }
        setTimeout(processNextInQueue, 1000);
        return; 
    } else {
        if (cooldownBanner) cooldownBanner.classList.add('hidden');
        localStorage.removeItem('admin_ai_cooldown');
    }

    const queue = getAIQueue();
    let activeTaskIndex = queue.findIndex(t => t.status === 'processing');
    if (activeTaskIndex === -1) {
        activeTaskIndex = queue.findIndex(t => t.status === 'waiting');
    }

    if (activeTaskIndex === -1) {
        isQueueProcessing = false; 
        if(typeof window.SketchwareJS !== 'undefined' && window.SketchwareJS.stopBackgroundService) {
            window.SketchwareJS.stopBackgroundService();
        }
        return;
    }

    const task = queue[activeTaskIndex];
    task.status = 'processing';
    saveAIQueue(queue);

    let subjectInstructions = "";
    if (['رياضيات', 'فيزياء', 'كيمياء', 'اقتصاد'].includes(task.subject)) {
        subjectInstructions = "هذه مادة علمية/رقمية. استخرج المسائل، القوانين، والمفاهيم العلمية الأساسية. للخيارات الخاطئة ضع نواتج أو مفاهيم قريبة للتمويه، وتأكد أن الإجابة الصحيحة دقيقة علمياً. استخدم صيغة LaTeX الرياضية (بين $ للسطري و $$ للمستقل) للأرقام والمعادلات.";
    } else if (['انكليزي', 'عربي', 'قواعد', 'ادب'].includes(task.subject)) {
        subjectInstructions = "هذه مادة لغوية/أدبية. ركز على القواعد والمفردات والإعراب والأحكام المذكورة حصراً في النص. اجعل الخيارات الخاطئة قريبة لغوياً.";
    } else {
        subjectInstructions = "هذه مادة حفظية/شرحيات. استخرج أسئلة واضحة من التعاليل، التعاريف، والأسس المهمة في صلب النص فقط.";
    }

    const mixedPrompt = `أنت أستاذ وموجه تربوي عراقي محترف تضع أسئلة وزارية. مهمتك وضع أسئلة ذكية، عادلة، ومنطقية جداً.
    المادة الحالية: ${task.subject}. 
    ${subjectInstructions}
    
    شروط الاستخراج (إجباري جداً):
    1. استخرج الأسئلة حصرياً من النص المرفق. يمنع منعاً باتاً تأليف أي معلومة خارجية.
    2. ممنوع الإشارة إلى أرقام الصفحات أو الملازم. اطرح السؤال العلمي مباشرة وكأنه في ورقة امتحان.
    3. يجب مسح وتوزيع الاستخراج على كامل مساحة النص المرفق لتغطيته بالكامل.
    4. المطلوب استخراج كمية ضخمة جداً: استخرج 200 سؤال اختيارات (MCQ) و 200 سؤال صح وخطأ (TF) (الهدف مجموع 400 سؤال فما فوق، وكلما تجاوزت هذا الرقم كان أفضل جداً).
    
    شروط الاختيارات (MCQ):
    1. لكل سؤال 3 خيارات فقط، خيار واحد صحيح.
    2. الخيارات الخاطئة هي مشتتات ذكية.
    
    شروط الصح والخطأ (TF):
    1. نصفها صح ونصفها خطأ تقريباً.
    2. لصياغة جملة خطأ، قم بتغيير كلمة مفصلية في حقيقة منهجية لتصبح خاطئة علمياً.
    
    الإرجاع:
    يجب أن ترجع كائن JSON يحتوي على مصفوفتين: mcq_questions و tf_questions.
    
    النص: ${task.fullText}`;

    const mixedSchema = {
        type: "OBJECT",
        properties: {
            mcq_questions: {
                type: "ARRAY",
                items: {
                    type: "OBJECT",
                    properties: {
                        question: { type: "STRING" },
                        answers: { type: "ARRAY", items: { type: "STRING" } },
                        correct: { type: "INTEGER" }
                    },
                    required: ["question", "answers", "correct"]
                }
            },
            tf_questions: {
                type: "ARRAY",
                items: {
                    type: "OBJECT",
                    properties: {
                        question: { type: "STRING" },
                        correct: { type: "BOOLEAN" }
                    },
                    required: ["question", "correct"]
                }
            }
        },
        required: ["mcq_questions", "tf_questions"]
    };

    let isExtractionSuccessful = false;
    let finalQuestions = [];
    let lastErrorMessage = "غير معروف";

    for (let keyIndex = 0; keyIndex < GEMINI_API_KEYS.length; keyIndex++) {
        const currentKey = GEMINI_API_KEYS[keyIndex];
        
        try {
            const modelsRes = await fetch(`https://generativelanguage.googleapis.com/v1beta/models?key=${currentKey}`);
            if (!modelsRes.ok) {
                console.log(`فشل المفتاح ${keyIndex + 1}، جاري تجربة المفتاح التالي...`);
                continue;
            }
            
            const modelsData = await modelsRes.json();
            const availableModels = modelsData.models.filter(m => 
                m.supportedGenerationMethods && 
                m.supportedGenerationMethods.includes("generateContent") && 
                m.name.includes("gemini")
            );

            if(availableModels.length === 0) continue;

            const targetModel = availableModels.find(m => m.name.includes("2.5") && m.name.includes("flash")) 
                             || availableModels.find(m => m.name.includes("2.0") && m.name.includes("flash"))
                             || availableModels.find(m => m.name.includes("flash")) 
                             || availableModels[0];

            console.log(`تم العثور على النموذج: ${targetModel.name} باستخدام المفتاح ${keyIndex + 1}`);

            const apiUrl = `https://generativelanguage.googleapis.com/v1beta/${targetModel.name}:generateContent?key=${currentKey}`;
            
            const response = await fetch(apiUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    contents: [{ parts: [{ text: mixedPrompt }] }],
                    generationConfig: { response_mime_type: "application/json", response_schema: mixedSchema, temperature: 0.6 }
                })
            });

            const result = await response.json();

            if (response.ok && !result.error) {
                const questionsText = result.candidates[0].content.parts[0].text;
                const parsedData = JSON.parse(questionsText);
                
                let mcqRaw = parsedData.mcq_questions || [];
                let tfRaw = parsedData.tf_questions || [];
                
                if (mcqRaw.length > 0 || tfRaw.length > 0) {
                    let combined = [];
                    
                    mcqRaw.forEach(q => {
                        let safeAnswers = q.answers || q.options || q.choices || ["خطأ", "تمويه", "نقص"];
                        combined.push({
                            type: 'mcq',
                            question: q.question || "سؤال غير معروف",
                            answers: safeAnswers,
                            correct: typeof q.correct === 'number' ? q.correct : 0
                        });
                    });
                    
                    tfRaw.forEach(q => {
                        let isTrue = true;
                        if (q.correct === false || q.correct === 'false' || q.correct === 0) isTrue = false;
                        combined.push({
                            type: 'tf',
                            question: q.question || "سؤال غير معروف",
                            correct: isTrue
                        });
                    });
                    
                    // خلط الأسئلة المستخرجة (اختياري بس يرتبها)
                    for (let i = combined.length - 1; i > 0; i--) {
                        const j = Math.floor(Math.random() * (i + 1));
                        [combined[i], combined[j]] = [combined[j], combined[i]];
                    }
                    
                    finalQuestions = combined;
                    isExtractionSuccessful = true;
                    console.log(`تم استخراج ${mcqRaw.length} اختيارات و ${tfRaw.length} صح وخطأ بنجاح باستخدام المفتاح ${keyIndex + 1}`);
                    break;
                }
            } else {
                lastErrorMessage = result.error?.message || "خطأ في الاستجابة";
                console.log(`المفتاح ${keyIndex + 1} فشل، جاري المحاولة...`);
            }
        } catch (e) {
            lastErrorMessage = e.message;
        }
    }

    const finalQueue = getAIQueue();
    const taskToUpdate = finalQueue.find(t => t.id === task.id);
    
    if (taskToUpdate) {
        if (isExtractionSuccessful && finalQuestions.length > 0) {
            taskToUpdate.questions = finalQuestions;
            taskToUpdate.status = 'extracted';
            taskToUpdate.processedChunks = 1; 
            taskToUpdate.fullText = ""; 
        } else {
            taskToUpdate.status = 'failed';
            taskToUpdate.errorReason = lastErrorMessage || "استنفدت جميع المفاتيح قدرتها أو النص غير صالح.";
        }
        saveAIQueue(finalQueue);
    }

    setTimeout(processNextInQueue, 2000); 
}

window.retryAITask = function(taskId) {
    const queue = getAIQueue();
    const task = queue.find(t => t.id === taskId);
    if(task) {
        task.status = 'waiting';
        saveAIQueue(queue);
        startAIQueueProcessor();
    }
};

window.clearCompletedAITasks = function() {
    const queue = getAIQueue();
    // إبقاء المهام التي قيد المعالجة (processing) فقط، ومسح (المكتمل، الفاشل، والانتظار المعلق)
    const newQueue = queue.filter(t => t.status === 'processing');
    saveAIQueue(newQueue);
};

