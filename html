    document.getElementById('searching-ui').style.display = 'flex';
    document.getElementById('search-msg').innerText = "جاري تجهيز الاختبار الشامل (30 سؤال)... 📝";

    try {
        const qMCQ = await getQuestions(sub, chap, 'mcq');
        const qTF = await getQuestions(sub, chap, 'tf');
        // جلب 30 سؤال مختلط
        let combinedQs = qMCQ.concat(qTF);
        for (let i = combinedQs.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [combinedQs[i], combinedQs[j]] = [combinedQs[j], combinedQs[i]];
        }
        let allQs = combinedQs.slice(0, 30);

        if(allQs.length < 15) {
            showBeautifulAlert('error', 'نقص أسئلة', 'لا توجد أسئلة كافية في هذا الفصل حالياً لاختبارك (يجب توفر 15 سؤال على الأقل).');
            cancelSearch(); return;
