async function startStudentMatch(sub, chapter, opponent) {
            if (!opponent || !opponent.id) { cancelSearch(); return; }
            
            let qDocs = [];
            try { qDocs = await getQuestions(sub, chapter, selectedQType); } catch (error) { console.error(error); }
            
            if (qDocs.length === 0) {
                showBeautifulAlert('error', 'عذراً', `لا توجد أسئلة كافية في "${chapter}" لمادة ${sub}. جرب فصلاً آخر.`);
                cancelSearch();
                return;
            }
            
            let limit = isPremiumValid(userData) ? 15 : 10;
            
            // خوارزمية Fisher-Yates لضمان عشوائية مطلقة في سحب الأسئلة (مستحيل التكرار النمطي)
            let shuffledArray = [...qDocs];
            for (let i = shuffledArray.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [shuffledArray[i], shuffledArray[j]] = [shuffledArray[j], shuffledArray[i]];
            }
            const shuffledQs = shuffledArray.slice(0, limit);
            
            localMatchData = {
                status: 'active', grade: userData.grade,
                player1: { uid: currentUser.uid, name: userData.name, score: 0, photo: userData.photo, grade: userData.grade },
                player2: { uid: opponent.id, name: opponent.name, score: 0, photo: opponent.photo, grade: opponent.grade },
                questions: shuffledQs, currentIdx: 0, answersCount: 0, totalQuestions: limit, subject: sub, chapter: chapter
            };
            
            // ⚠️ التعديل المهم: حفظ كل التفاصيل (الخصم ونوع اللعبة) حتى ما يصفن الذكاء الاصطناعي من ترجع
            const session = {
                matchData: localMatchData,
