    if (!friendId) return;
    if (friendId === userData.uniqueId) {
        showBeautifulAlert('warning', 'تنبيه', 'لا يمكنك البحث عن نفسك!');
        return;
    }

    resultDiv.classList.remove('hidden');
    resultDiv.innerHTML = '<i class="fas fa-spinner fa-spin text-indigo-500 text-2xl"></i>';

    try {
        const q = query(collection(db, "users"), where("uniqueId", "==", friendId));
        const snap = await getDocs(q);

        if (snap.empty) {
            resultDiv.innerHTML = '<p class="text-red-500 font-bold">المستخدم غير موجود ❌</p>';
