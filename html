                    localStorage.setItem('last_winning_gov', JSON.stringify({
                        name: winningGov, 
                        expiry: expiryDate,
                        weekId: currentWeekId
                    }));
                }

                let globalBatch = writeBatch(db);
                const allGovernorates = [
                    "بغداد", "البصرة", "نينوى", "بابل", "النجف", "كربلاء", 
                    "ذي قار", "القادسية", "المثنى", "ميسان", "واسط", "ديالى", 
