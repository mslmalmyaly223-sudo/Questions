window.syncQuestionsPacket = async function() {
    const updateScreen = document.getElementById('update-packet-screen');
    const progBar = document.getElementById('update-progress-bar');
    const statusTxt = document.getElementById('update-status-text');
    
    try {
        if (typeof localforage === 'undefined') {
            showBeautifulAlert('error', 'خطأ برمجي', 'مكتبة localforage غير موجودة! تأكد من إضافتها في قسم الـ head.');
            return;
        }

        const infoDoc = await getDoc(doc(db, "system_settings", "packet_info"));
        
        if (infoDoc.exists()) {
            const infoData = infoDoc.data();
            const serverTimestamp = infoData.updatedAt;
            const bundleUrl = infoData.bundleUrl;
            
            const localTimestamp = await localforage.getItem('packet_timestamp');

            if (!localTimestamp || localTimestamp < serverTimestamp) {
                updateScreen.classList.remove('hidden');
