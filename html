window.approveAITask = async function() {
    if (!currentViewingTask || !confirm("هل تريد إرسال هذه الأسئلة إلى قسم المراجعة للتدقيق النهائي؟")) return;
    
    const btn = document.getElementById('btn-approve-ai');
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الإرسال...';
    btn.disabled = true;

    try {
        const batch = writeBatch(db);
        let opCount = 0;
        let batches = [];

        for (const q of currentViewingTask.questions) {
            const newDocRef = doc(collection(db, "pending_questions"));
            batch.set(newDocRef, {
                question: q.question,
                answers: q.answers || null,
                correct: q.correct,
                type: q.type, // تم التعديل ليأخذ النوع من السؤال نفسه
                grade: currentViewingTask.grade,
                subject: currentViewingTask.subject,
                chapter: currentViewingTask.chapter,
                senderId: 'AI_GEMINI',
                senderName: 'المستخرج الذكي التلقائي 🤖',
                status: 'pending',
                createdAt: serverTimestamp()
            });
            opCount++;
            
            if (opCount >= 490) {
                batches.push(batch.commit());
                batch = writeBatch(db);
                opCount = 0;
            }
        }
        
        if (opCount > 0) batches.push(batch.commit());
        await Promise.all(batches);

        const queue = getAIQueue();
        const newQueue = queue.filter(t => t.id !== currentViewingTask.id);
        saveAIQueue(newQueue);
        
        closeAIReviewModal();
        showBeautifulAlert('success', 'تم الإرسال', 'تم إرسال الأسئلة لقسم المراجعة بنجاح! يمكنك الموافقة عليها بشكل نهائي من هناك.');

    } catch (e) {
        console.error(e);
        showBeautifulAlert('error', 'خطأ', 'حدث خطأ أثناء الإرسال.');
    } finally {
        btn.innerHTML = 'إرسال للمراجعة ✅';
        btn.disabled = false;
    }
};

window.rejectAITask = function() {
    if (!currentViewingTask || !confirm("هل أنت متأكد من رفض هذه التشكيلة وحذفها نهائياً؟")) return;
    
    const queue = getAIQueue();
    const newQueue = queue.filter(t => t.id !== currentViewingTask.id);
    saveAIQueue(newQueue);
    
    closeAIReviewModal();
    showBeautifulAlert('info', 'تم الرفض', 'تم حذف نتيجة الاستخراج من الطابور.');
};

