        const activeScreen = document.querySelector('.screen.active');
        if (activeScreen && activeScreen.id === 'tab-challenges') {
            const now = Date.now();
            if (now - lastBackPressTime < 2000) {
                // ضغط مرتين خلال ثانيتين = خروج
