};

window.preloadAndSetAvatar = async function(gender) {
    if (!gender || !AVATAR_URLS[gender]) {
        gender = 'boy'; 
    }
    
    const url = AVATAR_URLS[gender];
    const viewer = document.getElementById('avatar-3d-model');
    
    if (!viewer) return;
    
    try {
        // فتح ذاكرة التخزين المؤقتة الخاصة بالتطبيق
        const cache = await caches.open('hacker-avatar-cache-v1');
        let response = await cache.match(url);
        
        // إذا المجسم ما موجود بالذاكرة، نحمله ونحفظه
        if (!response) {
            console.log("جاري تحميل المجسم لأول مرة وحفظه...");
            response = await fetch(url);
            if (response.ok) {
                cache.put(url, response.clone());
            }
        } else {
            console.log("تم تحميل المجسم من الذاكرة بسرعة!");
        }
        
        // تحويل الملف إلى رابط محلي سريع جداً
        const blob = await response.blob();
        viewer.src = URL.createObjectURL(blob);
    } catch (error) {
        console.error("خطأ في نظام الكاش، جاري التحميل المباشر:", error);
        viewer.src = url; // في حالة الخطأ يرجع للطريقة القديمة
    }
};
     
