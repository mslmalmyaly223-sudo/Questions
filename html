        function isPremiumValid(user) {
            if(!user.isPremium || !user.premiumExpiry) return false;
            
            try {
                const now = new Date();
                let expiry;
                
                // توافقية كاملة مع جميع صيغ الوقت لتجنب انهيار الكود
                if (typeof user.premiumExpiry.toDate === 'function') {
                    expiry = user.premiumExpiry.toDate();
                } else if (user.premiumExpiry.seconds) {
                    expiry = new Date(user.premiumExpiry.seconds * 1000);
                } else {
                    expiry = new Date(user.premiumExpiry);
                }
                
                const isValid = expiry > now;
                
                // التأكد من وجود uid قبل الإيقاف لتجنب مشاكل الصلاحيات
                if (!isValid && user.isPremium && user.uid) {
                    deactivatePremiumFeatures(user.uid);
                }
                
                return isValid;
            } catch (error) {
                console.error("Error parsing premium date:", error);
                return false;
            }
        }

