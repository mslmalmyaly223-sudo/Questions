    safeSetText('pub-profile-points', '0');
    safeSetText('pub-profile-money', '$0');
    safeSetText('pub-stat-best-rank', '-');
    safeSetText('pub-stat-worst-rank', '-');
    safeSetText('pub-stat-winstreak', '0');
    safeSetText('pub-stat-correct', '0');
    safeSetText('pub-stat-worst', '0');
    safeSetText('pub-last-seen', 'جاري الحساب...');
    
    const onlineStatus = document.getElementById('pub-online-status');
    if (onlineStatus) onlineStatus.className = 'absolute bottom-1 right-1 w-4 h-4 bg-gray-400 border-2 border-white rounded-full shadow-sm';

    const headerBg = document.getElementById('pub-profile-header-bg');
    if (headerBg) headerBg.className = 'w-full h-28 relative rounded-b-[2.5rem] shadow-md z-10 transition-all duration-500 bg-gradient-to-r from-indigo-500 to-purple-600';
    
    const fullBg = document.getElementById('pub-profile-full-bg');
    if (fullBg) fullBg.className = 'absolute inset-0 z-0 opacity-10 transition-all duration-500';

    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    const profileScreen = document.getElementById('screen-public-profile');
    if (profileScreen) profileScreen.classList.add('active');

    try {
        const userDoc = await getDoc(doc(db, "users", uid));
        if (!userDoc.exists()) {
            showBeautifulAlert('error', 'خطأ', 'المستخدم غير موجود');
            closePublicProfile();
            return;
        }

        const u = userDoc.data();

        safeSetSrc('pub-profile-img', u.photo || 'https://ui-avatars.com/api/?name=User');
        safeSetText('pub-profile-id', u.uniqueId || 'غير متوفر');
        
        const copyBtn = document.getElementById('pub-btn-copy-id');
        if (copyBtn && u.uniqueId) copyBtn.onclick = () => window.copyIdText(u.uniqueId);

        let nameHtml = `<h2 id="pub-profile-name" class="text-xl font-black text-gray-800 drop-shadow-sm">${u.name || 'مستخدم مجهول'}</h2>`;
        if (isPremiumValid(u) && u.selectedBadge) {
            nameHtml += `<span class="px-2.5 py-0.5 text-[10px] text-white rounded-md shadow-[0_2px_8px_rgba(0,0,0,0.3)] font-bold ml-1.5 border border-white/60" style="background-color: ${u.selectedBadgeColor || '#f59e0b'}">${u.selectedBadge}</span>`;
        }
        safeSetHTML('pub-profile-name-container', nameHtml);

        safeSetText('pub-profile-grade', u.grade ? getGradeName(u.grade) : 'مرحلة غير محددة');

        if (u.governorate && govSpan) {
            govSpan.innerText = u.governorate;
            govSpan.classList.remove('hidden');
        }

        safeSetText('pub-profile-bio', u.bio || 'لا توجد سيرة ذاتية');
        safeSetText('pub-profile-points', u.points || 0);
        safeSetText('pub-profile-money', `$${u.balance || 0}`);
        safeSetText('pub-stat-best-rank', u.bestRank ? `#${u.bestRank}` : '-');
        safeSetText('pub-stat-worst-rank', u.worstRank ? `#${u.worstRank}` : '-');
        safeSetText('pub-stat-winstreak', u.bestWinStreak || u.winStreak || 0);
        safeSetText('pub-stat-correct', u.bestCorrectStreak || 0);
        safeSetText('pub-stat-worst', u.worstMatchScore !== undefined ? u.worstMatchScore : '-');

        let lastSeenText = 'غير متصل منذ فترة';
        let isOnline = false;

        const lastLoginValue = u.lastLogin;
        if (lastLoginValue) {
            let lastLoginDate;
            if (typeof lastLoginValue === 'string') {
                lastLoginDate = new Date(lastLoginValue);
            } else if (typeof lastLoginValue.toDate === 'function') {
                lastLoginDate = lastLoginValue.toDate();
            } else if (lastLoginValue.seconds) {
                lastLoginDate = new Date(lastLoginValue.seconds * 1000);
            } else {
                lastLoginDate = new Date(lastLoginValue);
            }
            
            if (!isNaN(lastLoginDate.getTime())) {
                const diffMs = Date.now() - lastLoginDate.getTime();
                const diffMins = Math.floor(diffMs / 60000);
                const diffHours = Math.floor(diffMs / 3600000);
                const diffDays = Math.floor(diffMs / 86400000);

                if (diffMins < 1) {
                    lastSeenText = 'متصل الآن 🟢';
                    isOnline = true;
                } else if (diffMins < 60) {
                    lastSeenText = `آخر ظهور قبل ${diffMins} دقيقة`;
                } else if (diffHours < 24) {
                    lastSeenText = `آخر ظهور قبل ${diffHours} ساعة`;
                } else {
                    lastSeenText = `آخر ظهور قبل ${diffDays} يوم`;
                }
            }
        }

        safeSetText('pub-last-seen', lastSeenText);
        if (onlineStatus) {
