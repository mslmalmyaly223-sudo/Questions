function renderGame(data) {
    if (isExitingGame) return;
    
    const session = JSON.parse(localStorage.getItem('active_match_session'));
    if(session) {
        session.lastActive = Date.now();
        localStorage.setItem('active_match_session', JSON.stringify(session));
    }
    const totalQs = data.questions.length;
    if(!data.questions || data.currentIdx >= totalQs) { 
        endGame(data); 
        return; 
    }
    
    emojiUsedInCurrentQuestion = false;
    enableEmojiButtons();
    
    // تصفير الأدوات إذا كان السؤال الأول
    if (data.currentIdx === 0) {
        hackerToolsUsed = { freeze: false, fifty: false };
    }
    
    const q = data.questions[data.currentIdx];
    if (!q) { endGame(data); return; }
            
    document.getElementById('p1-name').innerText = userData.name;
    document.getElementById('game-p1-img').src = userData.photo;
    document.getElementById('p2-name').innerText = data.player2.name;
    document.getElementById('game-p2-img').src = data.player2.photo;
    document.getElementById('game-my-score').innerText = data.player1.score;
    document.getElementById('game-op-score').innerText = data.player2.score;

    const qTextEl = document.getElementById('q-text');
    if(qTextEl.innerText !== q.question) {
        hasAnsweredCurrentQ = false;
        userAnsweredCorrectly = false;
        currentQuestionCorrectAnswer = null;
        clearTimeout(aiTimeoutId); 
        document.getElementById('answers-container').classList.remove('pointer-events-none', 'opacity-50');
        document.getElementById('waiting-msg').classList.add('hidden');
        document.getElementById('weak-signal').classList.add('hidden');
        
        emojiUsedInCurrentQuestion = false;
        enableEmojiButtons();
        
        // ------------------------------------------------------------
        // --- السحر هنا: بناء أزرار الهكر برمجياً لضمان ظهورها 100% ---
        let toolsContainer = document.getElementById('hacker-tools-container');
        if (!toolsContainer) {
            toolsContainer = document.createElement('div');
            toolsContainer.id = 'hacker-tools-container';
            toolsContainer.className = 'hidden justify-center gap-4 mb-4';
            toolsContainer.innerHTML = `
                <button id="tool-freeze" onclick="useFreezeTool()" class="bg-blue-100 text-blue-700 px-4 py-2 rounded-xl font-bold text-xs flex items-center gap-2 shadow-sm border border-blue-200 hover:bg-blue-200 active:scale-95 transition">
                    <i class="fas fa-snowflake"></i> تجميد 5ث
                </button>
                <button id="tool-fifty" onclick="useFiftyFiftyTool()" class="bg-purple-100 text-purple-700 px-4 py-2 rounded-xl font-bold text-xs flex items-center gap-2 shadow-sm border border-purple-200 hover:bg-purple-200 active:scale-95 transition">
                    <i class="fas fa-magic"></i> حذف إجابة
                </button>
            `;
            // نضيفها قبل الخيارات بالضبط حتى مستحيل تنمسح بالغلط
            const answersDiv = document.getElementById('answers-container');
            answersDiv.parentNode.insertBefore(toolsContainer, answersDiv);
        }

        // فحص الأمان للمميز (حتى لو النت بطيء، راح يعرفك مميز)
        let isUserPremium = false;
        try {
            isUserPremium = isPremiumValid(userData);
        } catch(e) {
            isUserPremium = userData && userData.isPremium;
        }

        // إذا مميز، واللعبة ضد طالب (وليس اختبار إنجاز)
        if (isUserPremium && currentGameMode !== 'achievement_test') {
            toolsContainer.classList.remove('hidden');
            toolsContainer.style.display = 'flex';
            
            const freezeBtn = document.getElementById('tool-freeze');
            const fiftyBtn = document.getElementById('tool-fifty');
            
            // تحديث شكل زر التجميد
            if (hackerToolsUsed.freeze) {
                freezeBtn.classList.add('opacity-50', 'pointer-events-none');
                freezeBtn.className = freezeBtn.className.replace('bg-blue-100', 'bg-gray-100').replace('text-blue-700', 'text-gray-400');
            } else {
                freezeBtn.classList.remove('opacity-50', 'pointer-events-none');
                freezeBtn.className = freezeBtn.className.replace('bg-gray-100', 'bg-blue-100').replace('text-gray-400', 'text-blue-700');
            }
            
            // تحديث شكل زر حذف الإجابة
            if (hackerToolsUsed.fifty || selectedQType === 'tf') {
                fiftyBtn.classList.add('opacity-50', 'pointer-events-none');
                fiftyBtn.className = fiftyBtn.className.replace('bg-purple-100', 'bg-gray-100').replace('text-purple-700', 'text-gray-400');
            } else {
                fiftyBtn.classList.remove('opacity-50', 'pointer-events-none');
                fiftyBtn.className = fiftyBtn.className.replace('bg-gray-100', 'bg-purple-100').replace('text-gray-400', 'text-purple-700');
            }
        } else {
            toolsContainer.classList.add('hidden');
            toolsContainer.style.display = 'none';
        }
        // ------------------------------------------------------------
        
        isTimerFrozen = false;
        document.getElementById('game-timer').classList.remove('text-blue-300', 'border-blue-400', 'border-4');
        
        clearInterval(gameTimer);
        let t = 15;
        document.getElementById('game-timer').innerText = t;
        gameTimer = setInterval(() => {
            if (isExitingGame) { clearInterval(gameTimer); return; }
            if (isTimerFrozen) return; // السحر: العداد يوكف إذا الأداة تفعلت

            t--;
            document.getElementById('game-timer').innerText = t;
            if(t <= 0) { 
                clearInterval(gameTimer); 
                if(!hasAnsweredCurrentQ) {
                    submitGameAnswer(null, q, data);
                } else {
                    handleAINextTurn();
                }
            }
        }, 1000);
        
        setupEmojiButtons();
    }
    
    document.getElementById('q-progress').innerText = `${data.currentIdx + 1} / ${data.totalQuestions || totalQs}`;
    
    qTextEl.innerText = q.question;
    const div = document.getElementById('answers-container');
    if(div.children.length === 0 || div.getAttribute('data-curr-q') !== q.question) {
        div.setAttribute('data-curr-q', q.question);
        div.innerHTML = '';
        let ansList = [];
        if(q.type === 'mcq') ansList = q.answers.map((txt, idx) => ({ txt, isCorrect: idx === q.correct, value: idx }));
        else ansList = [{ txt: 'صح', isCorrect: q.correct === 'true' || q.correct === true, value: 'true' }, { txt: 'خطأ', isCorrect: q.correct === 'false' || q.correct === false, value: 'false' }];
        
        const correctAns = ansList.find(ans => ans.isCorrect);
        if (correctAns) currentQuestionCorrectAnswer = correctAns.value;

        // خوارزمية Fisher-Yates لخلط أماكن الإجابات بشكل جذري ومستحيل الغش
        for (let i = ansList.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [ansList[i], ansList[j]] = [ansList[j], ansList[i]];
        }

        ansList.forEach(ansObj => {
            const btn = document.createElement('button');
            btn.className = "answer-neutral w-full py-4 border-2 rounded-xl text-lg font-bold shadow-sm active:scale-95 transition";
            btn.innerText = ansObj.txt;
            btn.dataset.value = ansObj.value;
            btn.onclick = () => { if(hasAnsweredCurrentQ) return; submitGameAnswer(ansObj, q, data); };
            div.appendChild(btn);
        });
    }

    if (window.MathJax) {
        setTimeout(() => {
            MathJax.typesetPromise([qTextEl, div]).catch((err) => console.log(err));
        }, 50);
    }
}

