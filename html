async function loadNotifications() {
    const listDiv = document.getElementById('notifications-list');
    if (!listDiv) {
        console.error("عنصر notifications-list غير موجود!");
        return;
    }
    
    listDiv.innerHTML = GLOBAL_LOADER_HTML;
    
    try {
        // التعديل السحري: نجلب إشعاراتك "أنت" حصراً من قاعدة البيانات لتظهر الإشعارات الأسبوعية 100%
        const q = query(
            collection(db, "notifications"), 
            where("userId", "==", currentUser.uid)
        );
        
        const snap = await getDocs(q);
        let userNotifications = [];
        const now = getIraqDate().getTime();
        
        snap.docs.forEach(docSnapshot => {
            const data = docSnapshot.data();
            const notifDate = data.createdAt ? data.createdAt.toDate().getTime() : 0;
            const hoursDiff = (now - notifDate) / (1000 * 60 * 60);

            if (data.read && hoursDiff >= 24) {
                try { deleteDoc(doc(db, "notifications", docSnapshot.id)); } catch(e) { }
            } else {
                userNotifications.push({ id: docSnapshot.id, ...data });
            }
        });
        
        // ترتيبها حسب الوقت لأننا مسحنا اللمت الخاطئ
        userNotifications.sort((a, b) => {
            const tA = a.createdAt ? a.createdAt.toDate().getTime() : 0;
            const tB = b.createdAt ? b.createdAt.toDate().getTime() : 0;
            return tB - tA;
        });

        // أخذ أحدث 50 إشعار لعرضها في الشاشة فقط
        userNotifications = userNotifications.slice(0, 50);
        
        if (userNotifications.length === 0) {
            listDiv.innerHTML = `
                <div class="empty-notifications">
                    <i class="far fa-bell-slash"></i>
                    <p class="text-lg font-medium text-gray-600 mb-2">لا توجد إشعارات</p>
                    <p class="text-sm text-gray-400">سيظهر هنا أي إشعارات جديدة تتلقاها</p>
                </div>
            `;
            return;
        }
        
        let html = '';
        userNotifications.forEach(notification => {
            const data = notification;
            const timeAgo = getTimeAgo(data.createdAt?.toDate());
            
            let notificationClass = 'notification-item';
            let icon = 'fas fa-bell';
            let actionBtn = '';
            
            if (data.type === 'reward') {
                notificationClass += ' reward';
                icon = 'fas fa-gift';
            } else if (data.type === 'revenge') {
                notificationClass += ' revenge';
                icon = 'fas fa-fist-raised';
                actionBtn = `
                    <button onclick="startRevengeMatch('${data.opponentId}', '${data.opponentName || 'الخصم'}')" class="revenge-btn">
                        <i class="fas fa-redo"></i> طلب انتقام
                    </button>
                `;
            } else if (data.type === 'weekly') {
                notificationClass += ' weekly';
                icon = 'fas fa-trophy';
            }
            
            html += `
                <div class="${notificationClass} ${data.read ? 'opacity-80' : ''}">
                    <div class="notification-content">
                        <div class="notification-icon">
                            <i class="${icon}"></i>
                        </div>
                        <div class="notification-text">
                            <p class="notification-message">${data.message}</p>
                            <div class="notification-time">
                                <i class="far fa-clock"></i>
                                <span>${timeAgo}</span>
                            </div>
                            ${actionBtn}
                        </div>
                    </div>
                </div>
            `;
        });
        
        listDiv.innerHTML = html;
        
    } catch (error) {
        console.error("Error loading notifications:", error);
        listDiv.innerHTML = `
            <div class="bg-red-50 border border-red-200 rounded-xl p-6 text-center">
                <i class="fas fa-exclamation-triangle text-red-500 text-3xl mb-3"></i>
                <p class="text-red-700 font-bold">حدث خطأ في تحميل الإشعارات</p>
                <p class="text-red-600 text-sm mt-2">يرجى المحاولة لاحقاً</p>
                <button onclick="loadNotifications()" class="mt-4 bg-red-100 text-red-700 px-6 py-2 rounded-lg font-bold hover:bg-red-200 transition">
                    <i class="fas fa-redo"></i> إعادة المحاولة
                </button>
            </div>
        `;
    }
}



